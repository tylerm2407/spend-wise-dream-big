# ============================================================
# Supabase Edge Function Secrets — TEMPLATE
# ============================================================
# DO NOT put real values in this file.
# DO NOT commit a file named .env (it is in .gitignore).
#
# HOW TO USE:
#   Option A (deployed functions via Supabase dashboard):
#     Go to app.supabase.com → your project →
#     Edge Functions → Manage Secrets → add each key below.
#
#   Option B (local development with Supabase CLI):
#     Copy this file:  cp .env.example .env
#     Fill in real values in .env (never commit it).
#     Then run:  supabase functions serve
# ============================================================


# ── Supabase (auto-injected in deployed functions, needed locally) ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# ── Plaid ───────────────────────────────────────────────────────────
# Get these from: https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key

# sandbox   → for testing (use fake bank credentials)
# development → real accounts, limited items (free)
# production  → real accounts, unlimited (requires Plaid approval)
PLAID_ENV=sandbox


# ── Stripe ──────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_DEFAULT_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_NW_REFERRAL_COUPON=your_coupon_code


# ── RevenueCat ──────────────────────────────────────────────────────
# Get from: https://app.revenuecat.com → your project → API keys
REVENUECAT_API_KEY=your_revenuecat_api_key
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret


# ── AI Gateway ──────────────────────────────────────────────────────
LOVABLE_API_KEY=your_lovable_api_key


# ── NovaWealth SSO ──────────────────────────────────────────────────
# The anon key from the NovaWealth Supabase project
NOVAWEALTH_ANON_KEY=your_novawealth_anon_key
